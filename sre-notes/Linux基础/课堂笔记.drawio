<mxfile host="app.diagrams.net">
  <diagram name="第 1 页" id="kB2hXUNKdIwN-3lkd4op">
    <mxGraphModel dx="791" dy="489" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="OKh8898g8XAeWF6woGmt-2" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="&lt;b&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;操作系统5大功能&lt;/font&gt;&lt;/b&gt;" vertex="1">
          <mxGeometry height="30" width="110" x="10" y="10" as="geometry" />
        </mxCell>
        <mxCell id="OKh8898g8XAeWF6woGmt-3" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;labelPosition=center;verticalLabelPosition=middle;" value="&lt;b&gt;处理器管理（processing management）：&lt;/b&gt;主要处理处理器的中段事件，其次是处理器调度。在单用户单任务的情况下，处理器仅为一个任务所占，进程管理的工作十分简单。但在多道程序或多用户的情况下，组织多个作业多个任务时，需要解决处理器调度、分配、回收等问题。" vertex="1">
          <mxGeometry height="70" width="770" x="10" y="30" as="geometry" />
        </mxCell>
        <mxCell id="OKh8898g8XAeWF6woGmt-5" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;labelPosition=center;verticalLabelPosition=middle;" value="&lt;b&gt;存储管理（memory management）：&lt;/b&gt;只要是对内存的分配、保护和扩充，主要包括存储分配、存储共享、存储保护、存储扩张。" vertex="1">
          <mxGeometry height="40" width="770" x="10" y="90" as="geometry" />
        </mxCell>
        <mxCell id="OKh8898g8XAeWF6woGmt-7" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="&lt;b&gt;设备管理（device management）：&lt;/b&gt;对各类外部设备分配、设备传输控制和故障处理、对所有输入、输出设备的管理、保证设备的正常使用。" vertex="1">
          <mxGeometry height="30" width="760" x="10" y="130" as="geometry" />
        </mxCell>
        <mxCell id="OKh8898g8XAeWF6woGmt-8" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="&lt;b&gt;文件管理（file system management）：&lt;/b&gt;文件存储空间的管理、目录管理、文件操作管理、文件保护。主要对文件的逻辑组织和物理组织，目录的结构进行管理，支持文件的存储、检索和修改。" vertex="1">
          <mxGeometry height="30" width="770" x="10" y="170" as="geometry" />
        </mxCell>
        <mxCell id="OKh8898g8XAeWF6woGmt-9" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="&lt;b&gt;作业管理（job management）：&lt;/b&gt;提供人机交互界面，可命令行，可图形，负责处理用户提交的诸多作业，为用户提供一个友好的操作环境。" vertex="1">
          <mxGeometry height="30" width="770" x="10" y="210" as="geometry" />
        </mxCell>
        <mxCell id="OKh8898g8XAeWF6woGmt-10" parent="1" style="rounded=0;whiteSpace=wrap;html=1;movable=1;resizable=1;rotatable=1;deletable=1;editable=1;locked=0;connectable=1;" value="" vertex="1">
